// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum Country {
  INDIA
  AMERICA
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  firstName      String          @map("first_name")
  lastName       String          @map("last_name")
  role           Role            @default(MEMBER)
  country        Country         @default(INDIA)
  orders         Order[]
  paymentMethods PaymentMethod[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model Restaurant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String
  rating    Float?
  country   Country
  imageUrl  String?  @map("image_url")
  menus     Menu[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("restaurants")
}

model Menu {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String     @map("restaurant_id") @db.Uuid
  dishes       Dish[]
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("menus")
}

model Dish {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  price       Decimal     @db.Decimal(10, 2)
  description String?
  menu        Menu        @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId      String      @map("menu_id") @db.Uuid
  imageUrl    String?     @map("image_url")
  isAvailable Boolean     @default(true) @map("is_available")
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("dishes")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  customer        User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId      String      @map("customer_id") @db.Uuid
  items           OrderItem[]
  totalPrice      Decimal     @map("total_price") @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  deliveryAddress String      @map("delivery_address")
  country         Country
  payment         Payment?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id       String  @id @default(uuid()) @db.Uuid
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId  String  @map("order_id") @db.Uuid
  dish     Dish?   @relation(fields: [dishId], references: [id], onDelete: SetNull)
  dishId   String? @map("dish_id") @db.Uuid
  quantity Int
  price    Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model PaymentMethod {
  id          String    @id @default(uuid()) @db.Uuid
  type        String // CARD / UPI / WALLET
  provider    String // Visa / Mastercard / GPay etc.
  last4       String?
  expiryMonth Int?      @map("expiry_month")
  expiryYear  Int?      @map("expiry_year")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String    @map("user_id") @db.Uuid
  payments    Payment[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("payment_methods")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String        @unique @map("order_id") @db.Uuid
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId String        @map("payment_method_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("payments")
}
